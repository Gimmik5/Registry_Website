# ============================================================
# ENVIRONMENT VARIABLES TEMPLATE
# ============================================================
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local or .env to git — they contain secrets.
# ============================================================

# ------------------------------------------------------------
# DATABASE (Neon PostgreSQL)
# ------------------------------------------------------------
# Your Neon connection string. Get it from: https://console.neon.tech
# Format: postgresql://user:password@host/database?sslmode=require
DATABASE_URL="postgresql://user:password@host.neon.tech/registry?sslmode=require"

# ------------------------------------------------------------
# NEXTAUTH (Authentication)
# ------------------------------------------------------------
# The URL your app is served from. http://localhost:3000 for local dev.
NEXTAUTH_URL="http://localhost:3000"

# A random secret used to sign session cookies.
# Generate one with: openssl rand -base64 32
# Or online: https://generate-secret.vercel.app/32
NEXTAUTH_SECRET="generate-a-random-32-character-string-here"

# ------------------------------------------------------------
# ADMIN CREDENTIALS
# ------------------------------------------------------------
# The admin username and password (for you to manage the registry).
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="change-this-to-something-secure"

# ------------------------------------------------------------
# GUEST CREDENTIALS
# ------------------------------------------------------------
# Shared login for all wedding guests.
GUEST_USERNAME="guests"
GUEST_PASSWORD="change-this-and-share-with-guests"

# ------------------------------------------------------------
# STRIPE (Payments)
# ------------------------------------------------------------
# Get test keys from: https://dashboard.stripe.com/test/apikeys
# Use test keys (pk_test_... and sk_test_...) during development.
# Switch to live keys only when ready to accept real payments.
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_SECRET_KEY="sk_test_..."

# Webhook signing secret (for verifying Stripe webhooks).
# Get it from: https://dashboard.stripe.com/test/webhooks
# For local dev, use `stripe listen` CLI tool to get a temporary secret.
STRIPE_WEBHOOK_SECRET="whsec_..."

# ------------------------------------------------------------
# CLOUDINARY (Image storage)
# ------------------------------------------------------------
# Free account: https://cloudinary.com/users/register/free
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# ------------------------------------------------------------
# RESEND (Email)
# ------------------------------------------------------------
# Free account: https://resend.com/signup
RESEND_API_KEY="re_..."

# The email address that sends notifications
EMAIL_FROM="registry@emandgidsatquendon.com"

# Admin email address (receives purchase notifications)
ADMIN_EMAIL="your-email@example.com"
